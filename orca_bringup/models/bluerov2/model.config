<?xml version="1.0"?>

<!-- gz sim will check /usr/share for models, and there is a GNOME package named 'orca' that lives there. -->
<!-- So, name this model 'orca5' to avoid a conflict. -->
<!-- See: https://answers.gazebosim.org/question/28549/gz_sim_resource_path-includes-usrshare/ -->

<model>
  <name>BlueROV2 Heavy</name>
  <version>4.0</version>
  <sdf version="1.6">model.sdf</sdf>

  <author>
    <name>Daniel</name>
    <email>clyde@mcqueen.net</email>
  </author>

  <maintainer email="daniel.regner@labmetro.ufsc.br">Daniel Regner</maintainer>

  <description>
    BlueROV2 orca5 model
  </description>
</model>
